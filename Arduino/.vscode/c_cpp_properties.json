{
    "version": 4,
    "env": {
        "ARDUINO_AVR": "C:/Users/vince/AppData/Local/Arduino15/packages/arduino/hardware/avr/1.8.8",
        "ARDUINO_TOOLS": "C:/Users/vince/AppData/Local/Arduino15/packages/arduino/tools",
        "AVR_GCC": "C:/Users/vince/AppData/Local/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino7",
        "USER_LIBS": "C:/Users/vince/Documents/Arduino/libraries"
    },
    "configurations": [
        {
            "name": "Arduino_Win",

            "includePath": [
                "${workspaceFolder}/**",
                "${env:ARDUINO_AVR}/cores/arduino",
                "${env:ARDUINO_AVR}/variants/standard",
                "${env:ARDUINO_AVR}/libraries",
                "${env:ARDUINO_TOOLS}/avr/include",
                "${env:AVR_GCC}/lib/gcc/avr/7.3.0/include",
                "${env:AVR_GCC}/lib/gcc/avr/7.3.0/include-fixed"
            ],

            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${env:ARDUINO_AVR}/cores/arduino",
                    "${env:ARDUINO_AVR}/variants/standard",
                    "${env:ARDUINO_AVR}/libraries",
                    "${env:AVR_GCC}/avr/include",
                    "${env:AVR_GCC}/lib/gcc/avr/7.3.0/include",
                    "${env:AVR_GCC}/lib/gcc/avr/7.3.0/include-fixed",
                    "${env:USER_LIBS}"
                ],
                "limitSymbolsToIncludedHeaders": true
            },

            "defines": [
                "ARDUINO",
                "ARDUINO_AVR_UNO",
                "ARDUINO_ARCH_AVR",
                "USBCON"
            ],

            "windowsSdkVersion": "10.0.17763.0",
            "compilerPath": "${env:AVR_GCC}/bin/avr-g++",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64",

            "forcedInclude": [
                "${env:ARDUINO_AVR}/cores/arduino/Arduino.h"
            ]
        }
    ]
}